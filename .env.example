# YouTube OAuth2 credentials
# Download client_secrets.json from Google Cloud Console:
# APIs & Services > Credentials > OAuth 2.0 Client ID > Download JSON
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_CHANNEL_ID=

# Separator model: htdemucs | mdxnet
SEPARATOR_MODEL=htdemucs

# Directories (relative to project root)
OUTPUT_DIR=output
TMP_DIR=tmp
DB_PATH=data/history.db

# Upload defaults: public | unlisted | private
DEFAULT_PRIVACY=unlisted
